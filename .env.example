# Variabel khusus untuk docker-compose.yml (root) — bukan .env milik Laravel.
# Copy ke `.env` di root, isi nilainya, lalu `docker compose up`.

# Password root MariaDB (dipakai container mysql + koneksi DB backend/frontend-v2).
MYSQL_ROOT_PASSWORD=root

# Ambil dari https://dashboard.ngrok.com/get-started/your-authtoken (akun ngrok gratis cukup).
# Dipakai untuk tunnel backend:8080 (webhook Midtrans) & frontend:8000 (testing pembayaran mobile).
NGROK_AUTHTOKEN=
